---
import MainLayout from '../layouts/main.astro';
import { MemoryFormWrapper } from '../components/MemoryFormWrapper';
import { baseUrl } from '../lib/base-url';

// CONFIGURATION:
// Get collection ID from environment variable
const COLLECTION_ID = import.meta.env.MEMORY_JOURNAL_COLLECTION_ID;

// Optional: Add your locale ID if using multiple locales
const LOCALE_ID = undefined; // or 'YOUR_LOCALE_ID_HERE'
---

<MainLayout>
<!-- Inject collection ID for embed auto-detection -->
<script is:inline define:vars={{ COLLECTION_ID }}>
  // Make collection ID available globally for embeds
  window.MEMORY_FORM_COLLECTION_ID = COLLECTION_ID;
</script>

<div class="min-h-screen bg-background"> 
<!-- Hero Section -->
<section class="relative overflow-hidden">
<div class="container mx-auto px-4 py-16 md:py-24">
<div class="max-w-4xl mx-auto text-center">
<h1 class="text-4xl md:text-6xl font-heading font-bold text-foreground mb-6">
Memories That Last Forever
</h1>
<p class="text-xl md:text-2xl text-muted-foreground mb-8">
Share your precious moments and create a lasting digital memory journal
</p>

<!-- Memory Form Button -->
<div class="flex justify-center">
<MemoryFormWrapper
client:only="react"
collectionId={COLLECTION_ID}
localeId={LOCALE_ID}
baseUrl={baseUrl}
buttonText="Share a Memory"
buttonVariant="Ocean Teal"
/>
</div>
</div>
</div>
</section>

<!-- Features Section -->
<section class="py-16 bg-muted/50">
<div class="container mx-auto px-4">
<div class="max-w-6xl mx-auto">
<h2 class="text-3xl font-heading font-bold text-center mb-12">
Preserve Your Special Moments
</h2>

<div class="grid md:grid-cols-3 gap-8">
<!-- Feature 1 -->
<div class="bg-card rounded-lg p-6 shadow-sm">
<div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
</svg>
</div>
<h3 class="text-xl font-heading font-semibold mb-2">Photos & Videos</h3>
<p class="text-muted-foreground">
Upload photos and videos to bring your memories to life
</p>
</div>

<!-- Feature 2 -->
<div class="bg-card rounded-lg p-6 shadow-sm">
<div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
</svg>
</div>
<h3 class="text-xl font-heading font-semibold mb-2">Tag & Organize</h3>
<p class="text-muted-foreground">
Add tags to categorize and easily find your memories later
</p>
</div>

<!-- Feature 3 -->
<div class="bg-card rounded-lg p-6 shadow-sm">
<div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
</svg>
</div>
<h3 class="text-xl font-heading font-semibold mb-2">Capture the Moment</h3>
<p class="text-muted-foreground">
Record dates and locations to remember when and where it happened
</p>
</div>
</div>
</div>
</div>
</section>

<!-- CTA Section -->
<section class="py-16">
<div class="container mx-auto px-4">
<div class="max-w-3xl mx-auto text-center">
<h2 class="text-3xl font-heading font-bold mb-4">
Start Your Memory Journal Today
</h2>
<p class="text-lg text-muted-foreground mb-8">
Don't let your precious moments fade away. Share them and keep them alive forever.
</p>

<MemoryFormWrapper
client:only="react"
collectionId={COLLECTION_ID}
localeId={LOCALE_ID}
baseUrl={baseUrl}
buttonText="Get Started"
buttonVariant="Slate Navy"
/>
</div>
</div>
</section>
</div>
</MainLayout>

<style>
/* Custom styles for the memory page */
.container {
width: 100%;
max-width: 1280px;
}
</style>
