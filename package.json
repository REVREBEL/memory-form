{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "predev": "npx kill-port 3000 || true",
    "dev": "astro dev",
    "build": "astro build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:all": "npm run build && npm run build:embed",
    "preview": "astro build && wrangler dev",
    "astro": "astro",
    "cf-typegen": "wrangler types",
    "build:docs": "node ./scripts/build-master-doc.mjs",
    "cleanup": "rm -rf /tmp/* /var/tmp/* /root/.npm /root/.cache /root/.local /app/lost+found/* /app/dist 2>/dev/null || true && echo 'Cleanup complete!' && df -h / | tail -1"
