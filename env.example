# Webflow Memory Form - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================
# REQUIRED: Webflow CMS API Token
# ============================================================
# Get this from: Webflow Site Settings → Integrations → API Access
# Generate a Site API Token with CMS read/write permissions
WEBFLOW_CMS_SITE_API_TOKEN=your_site_api_token_here

# ============================================================
# OPTIONAL: Webflow API Host
# ============================================================
# Only needed for custom Webflow API endpoints (development/testing)
# Default: https://api.webflow.com
# WEBFLOW_API_HOST=https://api.webflow.com

# ============================================================
# NOTES
# ============================================================
# 
# 1. NEVER commit the .env file to version control
#    (it's already in .gitignore)
# 
# 2. For production deployment to Webflow Cloud:
#    - Set these variables in the Webflow Cloud dashboard
#    - Go to: App Settings → Environment Variables
# 
# 3. Collection ID configuration:
#    - Set in: src/pages/index.astro
#    - Get from: Webflow CMS collection settings
# 
# 4. Security:
#    - Keep your API token secret
#    - Rotate token if compromised
#    - Use different tokens for dev/staging/production
# 
# ============================================================
